---
import Base from '../../layouts/Base.astro';
import { getCollection } from 'astro:content';

const posts = (await getCollection('blog', ({ data }) => !data.draft))
  .sort((a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf());
---
<Base title="Writing — Augustus Nas">
<style>
  .blog-header { padding: 48px 40px 32px; border-bottom: 1px solid var(--rule); }
  .blog-headline { font-family: var(--serif); font-size: 42px; font-weight: 700; letter-spacing: -0.02em; margin-bottom: 8px; }
  .blog-sub { font-size: 14px; color: var(--mid); }
  .blog-list { border-bottom: 1px solid var(--rule); }
  .blog-row { display: grid; grid-template-columns: 80px 1fr auto; align-items: start; gap: 24px; padding: 28px 40px; border-bottom: 1px solid var(--rule); text-decoration: none; color: inherit; transition: background 0.15s; }
  .blog-row:hover { background: white; }
  .blog-row:last-child { border-bottom: none; }
  .blog-date { font-size: 13px; color: var(--mid); padding-top: 2px; }
  .post-tag { font-size: 10px; letter-spacing: 0.12em; text-transform: uppercase; color: var(--accent); margin-bottom: 8px; font-weight: 500; }
  .blog-row-title { font-family: var(--serif); font-size: 17px; font-weight: 700; line-height: 1.3; margin-bottom: 6px; }
  .blog-row-excerpt { font-size: 13px; color: var(--mid); line-height: 1.6; }
  .blog-arrow { font-size: 18px; color: var(--rule); padding-top: 2px; transition: color 0.15s; }
  .blog-row:hover .blog-arrow { color: var(--ink); }
  @media (max-width: 768px) {
    .blog-header { padding: 32px 20px 24px; }
    .blog-headline { font-size: 32px; }
    .blog-row { grid-template-columns: 1fr auto; gap: 12px; padding: 20px; }
    .blog-date { display: none; }
    .blog-row-title { font-size: 15px; }
  }
</style>

<div class="blog-header">
  <h1 class="blog-headline">Thinking</h1>
  <p class="blog-sub">Thinking on transformation, incentives, and why capable organisations make predictably bad decisions.</p>
</div>

<div class="blog-list">
  {posts.map(post => (
    <a class="blog-row" href={`/blog/${post.id}`}>
      <div class="blog-date">
        {post.data.pubDate.toLocaleDateString('en-GB', { month: 'short', year: 'numeric' })}
      </div>
      <div>
        {post.data.tags && <div class="post-tag">{post.data.tags[0]}</div>}
        <div class="blog-row-title">{post.data.title}</div>
        <div class="blog-row-excerpt">{post.data.description}</div>
      </div>
      <div class="blog-arrow">→</div>
    </a>
  ))}
</div>
</Base>