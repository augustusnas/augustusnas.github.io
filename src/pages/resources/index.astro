---
import Base from '../../layouts/Base.astro';
---
<Base title="Resources — Augustus Nas">
<style>
  .resources-header { padding: 48px 40px 32px; border-bottom: 1px solid var(--rule); }
  .resources-headline { font-family: var(--serif); font-size: 42px; font-weight: 700; letter-spacing: -0.02em; margin-bottom: 8px; }
  .resources-sub { font-size: 14px; color: var(--mid); }
  .tools-list { border-bottom: 1px solid var(--rule); }
  .tool-card { padding: 48px 40px; border-bottom: 1px solid var(--rule); }
  .tool-card:last-child { border-bottom: none; }
  .tool-title { font-family: var(--serif); font-size: 22px; font-weight: 700; line-height: 1.2; margin-bottom: 20px; letter-spacing: -0.01em; }
  .tool-desc { font-size: 14px; line-height: 1.85; color: var(--mid); max-width: 640px; margin-bottom: 28px; }
  .tool-download { display: inline-block; font-size: 12px; letter-spacing: 0.08em; text-transform: uppercase; color: var(--mid); border-bottom: 1px solid var(--rule); padding-bottom: 2px; cursor: default; }
  @media (max-width: 768px) {
    .resources-header { padding: 32px 20px 24px; }
    .resources-headline { font-size: 32px; }
    .tool-card { padding: 32px 20px; }
  }
</style>

<div class="resources-header">
  <h1 class="resources-headline">Diagnostic Tools</h1>
  <p class="resources-sub">Frameworks built from practice. Not adapted from textbooks.</p>
</div>

<div class="tools-list">
  <div class="tool-card">
    <div class="tool-title">The Change Politics Audit</div>
    <p class="tool-desc">Before any transformation programme moves into delivery, this diagnostic surfaces the political and incentive dynamics that will determine whether it lands. Fifteen questions across five dimensions: power distribution, incentive alignment, dependency mapping, resistance patterns, and decision architecture.</p>
    <span class="tool-download">Download — coming soon</span>
  </div>
  <div class="tool-card">
    <div class="tool-title">The Adoption Gap Diagnostic</div>
    <p class="tool-desc">For SaaS businesses where a platform is technically sound but customer adoption is underperforming. Identifies whether the gap is a product problem, a delivery problem, a customer expectation problem, or a combination. Used at the start of engagements to focus effort on the right lever.</p>
    <span class="tool-download">Download — coming soon</span>
  </div>
</div>
</Base>
